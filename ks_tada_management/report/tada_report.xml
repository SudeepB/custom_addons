<odoo>

    <!-- Report Action -->
    <record id="action_report_tada_request" model="ir.actions.report">
        <field name="name">TADA Request</field>
        <field name="model">ks.tada.request</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ks_tada_management.report_tada_request_document</field>
        <field name="report_file">ks_tada_management.report_tada_request_document</field>
        <field name="binding_model_id" ref="model_ks_tada_request"/>
        <field name="binding_type">report</field>
    </record>

    <!-- QWeb Template -->
    <template id="report_tada_request_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">

                        <h2 style="text-align:center;">TADA Request — <t t-esc="o.name"/></h2>
                        <hr/>

                        <!-- Basic Info -->
                        <table class="table table-sm" style="width:100%;">
                            <tr>
                                <td><strong>Employee</strong></td>
                                <td><t t-esc="o.employee_id.name"/></td>
                                <td><strong>Travel Type</strong></td>
                                <td><t t-esc="dict(o._fields['travel_type'].selection).get(o.travel_type, '')"/></td>
                            </tr>
                            <tr>
                                <td><strong>From Date</strong></td>
                                <td><t t-esc="o.from_date"/></td>
                                <td><strong>To Date</strong></td>
                                <td><t t-esc="o.to_date"/></td>
                            </tr>
                            <tr>
                                <td><strong>Destination</strong></td>
                                <td><t t-esc="o.destination"/></td>
                                <td><strong>Status</strong></td>
                                <td><t t-esc="dict(o._fields['state'].selection).get(o.state, '')"/></td>
                            </tr>
                            <tr t-if="o.travel_type == 'residential'">
                                <td><strong>Full-Board Package</strong></td>
                                <td><t t-esc="'Yes' if o.full_board else 'No'"/></td>
                                <td><strong>Vehicle Provided by KS</strong></td>
                                <td><t t-esc="'Yes' if o.with_vehicle else 'No'"/></td>
                            </tr>
                            <tr t-if="o.travel_type == 'local'">
                                <td><strong>KM Travelled</strong></td>
                                <td><t t-esc="o.km_travelled"/></td>
                                <td></td><td></td>
                            </tr>
                        </table>

                        <!-- Amount Summary -->
                        <h4 style="margin-top:16px;">Amount Summary</h4>
                        <table class="table table-sm" style="width:60%;">
                            <tr>
                                <td><strong>Bill Amount (NPR)</strong></td>
                                <td><t t-esc="'%.2f' % o.bill_amount"/></td>
                            </tr>
                            <tr>
                                <td><strong>Total Applied Amount (NPR)</strong></td>
                                <td><t t-esc="'%.2f' % o.amount"/></td>
                            </tr>
                        </table>
                        <pre style="background:#f8f8f8;padding:8px;font-size:11px;"><t t-esc="o.amount_breakdown"/></pre>

                        <!-- Bill Attachments -->
                        <t t-if="o.bill_line_ids">
                            <h4 style="margin-top:16px;">Bill Attachments</h4>
                            <table class="table table-bordered table-sm" style="width:100%;">
                                <thead>
                                    <tr>
                                        <th>File Name</th>
                                        <th>Amount (NPR)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.bill_line_ids" t-as="bill">
                                        <tr>
                                            <td><t t-esc="bill.bill_attachment_name or '—'"/></td>
                                            <td><t t-esc="'%.2f' % bill.bill_amount"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Travel Itinerary -->
                        <t t-if="o.itinerary_ids">
                            <h4 style="margin-top:16px;">Travel Itinerary</h4>
                            <table class="table table-bordered table-sm" style="width:100%;">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Travel From</th>
                                        <th>Travel To</th>
                                        <th>Mode of Transportation</th>
                                        <th>Remarks</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.itinerary_ids" t-as="itin">
                                        <tr>
                                            <td><t t-esc="itin.date"/></td>
                                            <td><t t-esc="itin.travel_from"/></td>
                                            <td><t t-esc="itin.travel_to"/></td>
                                            <td><t t-esc="itin.mode_of_transport"/></td>
                                            <td><t t-esc="itin.remarks"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Advance Request -->
                        <t t-if="o.advance_ids">
                            <h4 style="margin-top:16px;">Advance Request</h4>
                            <table class="table table-bordered table-sm" style="width:100%;">
                                <thead>
                                    <tr>
                                        <th>Activity Code</th>
                                        <th>Budget Line Item</th>
                                        <th>Advance (A)</th>
                                        <th>Settled Expenses</th>
                                        <th>Remarks</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.advance_ids" t-as="adv">
                                        <tr>
                                            <td><t t-esc="adv.activity_code"/></td>
                                            <td><t t-esc="adv.budget_line_item"/></td>
                                            <td><t t-esc="'%.2f' % adv.advance_amount"/></td>
                                            <td><t t-esc="'%.2f' % adv.settled_expenses"/></td>
                                            <td><t t-esc="adv.remarks"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Signatures -->
                        <table style="width:100%;margin-top:40px;">
                            <tr>
                                <td style="width:50%;text-align:center;">
                                    <div style="border-top:1px solid #000;display:inline-block;width:200px;padding-top:4px;">
                                        <strong>Submitted By</strong><br/>
                                        <t t-esc="o.submitted_by.name or '—'"/>
                                    </div>
                                </td>
                                <td style="width:50%;text-align:center;">
                                    <div style="border-top:1px solid #000;display:inline-block;width:200px;padding-top:4px;">
                                        <strong>Approved By</strong><br/>
                                        <t t-esc="o.approved_by.name or '—'"/>
                                    </div>
                                </td>
                            </tr>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
