<odoo>

    <!-- Report Action -->
    <record id="action_report_tada_request" model="ir.actions.report">
        <field name="name">Travel Authorization Form</field>
        <field name="model">ks.tada.request</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ks_tada_management.report_tada_request_document</field>
        <field name="report_file">ks_tada_management.report_tada_request_document</field>
        <field name="binding_model_id" ref="model_ks_tada_request"/>
        <field name="binding_type">report</field>
    </record>

    <!-- QWeb Template -->
    <template id="report_tada_request_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <!--
                    print_mode is passed via report context (with_context).
                    env.context is available in QWeb as a Python dict.
                    Default to 'both' when printing directly from Print menu.
                -->
                <t t-set="mode"         t-value="request.env.context.get('print_mode', 'both')"/>
                <t t-set="show_claim"   t-value="mode in ('claim', 'both')"/>
                <t t-set="show_advance" t-value="mode in ('advance', 'both')"/>

                <t t-call="web.external_layout">
                    <div class="page" style="font-family: Arial, sans-serif; font-size: 11pt; color: #000;">

                        <!-- ── HEADER ── -->
                        <div style="text-align:center; margin-bottom:6px;">
                            <h2 style="margin:0; font-size:15pt; font-weight:bold; letter-spacing:1px;">
                                Karkhana Samuha
                            </h2>
                            <h3 style="margin:2px 0 0 0; font-size:13pt; font-weight:bold;">
                                <t t-if="mode == 'advance'">Advance Request Form</t>
                                <t t-elif="mode == 'claim'">Travel Claim Form</t>
                                <t t-else="">Travel Authorization Form</t>
                            </h3>
                        </div>

                        <!-- File name row -->
                        <table style="width:100%; margin-bottom:10px;">
                            <tr>
                                <td style="width:15%;"><strong>File Name:</strong></td>
                                <td>
                                    <t t-esc="(o.employee_id.name or '').lower().replace(' ','_')"/>_taf_<t t-esc="o.from_date.strftime('%d%m%Y') if o.from_date else ''"/>
                                </td>
                            </tr>
                        </table>
                        <hr style="border:1.5px solid #000; margin:4px 0 10px 0;"/>

                        <!-- ── PERSONAL INFORMATION ── -->
                        <div style="background:#c8e6c9; padding:4px 8px; font-weight:bold; font-size:11pt; margin-bottom:4px;">
                            Personal Information
                        </div>
                        <table style="width:100%; border-collapse:collapse; margin-bottom:10px;">
                            <tr>
                                <td style="width:20%; padding:4px 6px;"><strong>Name</strong></td>
                                <td style="width:35%; padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="o.employee_id.name or '—'"/>
                                </td>
                                <td style="width:15%; padding:4px 6px; text-align:right;"><strong>Signature</strong></td>
                                <td style="width:30%; padding:4px 6px; border-bottom:1px solid #000;"></td>
                            </tr>
                            <tr>
                                <td style="padding:4px 6px;"><strong>Designation</strong></td>
                                <td style="padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="o.employee_id.job_id.name or '—'"/>
                                </td>
                                <td></td><td></td>
                            </tr>
                            <tr>
                                <td style="padding:4px 6px;"><strong>Team / Department</strong></td>
                                <td style="padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="o.employee_id.department_id.name or '—'"/>
                                </td>
                                <td></td><td></td>
                            </tr>
                        </table>

                        <!-- ── TRAVEL INFORMATION ── -->
                        <div style="background:#c8e6c9; padding:4px 8px; font-weight:bold; font-size:11pt; margin-bottom:4px;">
                            Travel Information
                        </div>
                        <table style="width:100%; border-collapse:collapse; margin-bottom:10px;">
                            <tr>
                                <td style="width:20%; padding:4px 6px;"><strong>Purpose of Travel</strong></td>
                                <td style="width:35%; padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="o.purpose_of_travel or '—'"/>
                                </td>
                                <td style="width:15%; padding:4px 6px;"><strong>Project / Programme</strong></td>
                                <td style="width:30%; padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="o.project_title or (o.programme_id.name if o.programme_id else '—')"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:4px 6px;"><strong>Date of Departure</strong></td>
                                <td style="padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="o.from_date.strftime('%d/%m/%Y') if o.from_date else '—'"/>
                                </td>
                                <td style="padding:4px 6px;"><strong>Date of Arrival</strong></td>
                                <td style="padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="o.to_date.strftime('%d/%m/%Y') if o.to_date else '—'"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:4px 6px;"><strong>Destination</strong></td>
                                <td style="padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="o.destination or '—'"/>
                                </td>
                                <td style="padding:4px 6px;"><strong>Primary Travel Type</strong></td>
                                <td style="padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="dict(o._fields['travel_type'].selection).get(o.travel_type, '—') if o.travel_type else '—'"/>
                                </td>
                            </tr>
                        </table>

                        <!-- ── TRAVEL LINES (multi-type) ── -->
                        <t t-if="o.travel_line_ids">
                            <div style="background:#c8e6c9; padding:4px 8px; font-weight:bold; font-size:11pt; margin-bottom:4px;">
                                Travel Details
                            </div>
                            <table style="width:100%; border-collapse:collapse; margin-bottom:10px;">
                                <thead>
                                    <tr style="background:#c8e6c9;">
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Programme / Project</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Travel Type</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:center;">People</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">From Date</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">To Date</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:right;">Amount (NPR)</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Breakdown</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.travel_line_ids" t-as="tl">
                                        <tr>
                                            <td style="border:1px solid #000; padding:4px 6px;">
                                                <t t-esc="tl.programme_id.name if tl.programme_id else '—'"/>
                                            </td>
                                            <td style="border:1px solid #000; padding:4px 6px;">
                                                <t t-esc="dict(tl._fields['travel_type'].selection).get(tl.travel_type, '—')"/>
                                            </td>
                                            <td style="border:1px solid #000; padding:4px 6px; text-align:center;">
                                                <t t-esc="tl.num_people"/>
                                            </td>
                                            <td style="border:1px solid #000; padding:4px 6px;">
                                                <t t-esc="tl.from_date.strftime('%d/%m/%Y') if tl.from_date else '—'"/>
                                            </td>
                                            <td style="border:1px solid #000; padding:4px 6px;">
                                                <t t-esc="tl.to_date.strftime('%d/%m/%Y') if tl.to_date else '—'"/>
                                            </td>
                                            <td style="border:1px solid #000; padding:4px 6px; text-align:right;">
                                                <t t-esc="'%.2f' % tl.line_amount"/>
                                            </td>
                                            <td style="border:1px solid #000; padding:4px 6px; font-size:9pt;">
                                                <t t-esc="tl.breakdown or ''"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot>
                                    <tr style="font-weight:bold; background:#f1f8e9;">
                                        <td colspan="5" style="border:1px solid #000; padding:4px 6px; text-align:right;">
                                            Travel Lines Total
                                        </td>
                                        <td style="border:1px solid #000; padding:4px 6px; text-align:right;">
                                            <t t-esc="'%.2f' % sum(o.travel_line_ids.mapped('line_amount'))"/>
                                        </td>
                                        <td style="border:1px solid #000; padding:4px 6px;"></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </t>

                        <!-- ── ITINERARY / SCHEDULE ── -->
                        <t t-if="o.itinerary_ids">
                            <div style="background:#c8e6c9; padding:4px 8px; font-weight:bold; font-size:11pt; margin-bottom:4px;">
                                Itinerary / Programme Schedule
                            </div>
                            <table style="width:100%; border-collapse:collapse; margin-bottom:10px;">
                                <thead>
                                    <tr style="background:#c8e6c9;">
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Date</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Programme / Project</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Activity Type</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Location / Venue</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">From</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">To</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Mode</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Remarks</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.itinerary_ids" t-as="itin">
                                        <tr>
                                            <td style="border:1px solid #000; padding:4px 6px;">
                                                <t t-esc="itin.date.strftime('%d/%m/%Y') if itin.date else '—'"/>
                                            </td>
                                            <td style="border:1px solid #000; padding:4px 6px;">
                                                <t t-esc="itin.programme_id.name if itin.programme_id else '—'"/>
                                            </td>
                                            <td style="border:1px solid #000; padding:4px 6px;">
                                                <t t-esc="dict(itin._fields['activity_type'].selection).get(itin.activity_type, '—')"/>
                                            </td>
                                            <td style="border:1px solid #000; padding:4px 6px;"><t t-esc="itin.location or ''"/></td>
                                            <td style="border:1px solid #000; padding:4px 6px;"><t t-esc="itin.travel_from or ''"/></td>
                                            <td style="border:1px solid #000; padding:4px 6px;"><t t-esc="itin.travel_to or ''"/></td>
                                            <td style="border:1px solid #000; padding:4px 6px;"><t t-esc="itin.mode_of_transport or ''"/></td>
                                            <td style="border:1px solid #000; padding:4px 6px;"><t t-esc="itin.remarks or ''"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- ── ADVANCE REQUEST ── -->
                        <t t-if="show_advance and o.advance_ids">
                            <div style="background:#c8e6c9; padding:4px 8px; font-weight:bold; font-size:11pt; margin-bottom:4px;">
                                Advance Request
                            </div>
                            <table style="width:100%; border-collapse:collapse; margin-bottom:4px;">
                                <thead>
                                    <tr style="background:#c8e6c9;">
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Date</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Programme / Project</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Member Category</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:center;">Members</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Budget Line</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:right;">Advance (NPR)</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Remarks / Calculation</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.advance_ids" t-as="adv">
                                        <tr>
                                            <td style="border:1px solid #000; padding:4px 6px;">
                                                <t t-esc="adv.date.strftime('%d/%m/%Y') if adv.date else '—'"/>
                                            </td>
                                            <td style="border:1px solid #000; padding:4px 6px;">
                                                <t t-esc="adv.programme_id.name if adv.programme_id else '—'"/>
                                            </td>
                                            <td style="border:1px solid #000; padding:4px 6px;">
                                                <t t-esc="dict(adv._fields['member_category'].selection).get(adv.member_category, '—')"/>
                                            </td>
                                            <td style="border:1px solid #000; padding:4px 6px; text-align:center;">
                                                <t t-esc="adv.member_count"/>
                                            </td>
                                            <td style="border:1px solid #000; padding:4px 6px;">
                                                <t t-esc="adv.budget_line_item or ''"/>
                                            </td>
                                            <td style="border:1px solid #000; padding:4px 6px; text-align:right;">
                                                <t t-esc="'%.2f' % adv.advance_amount"/>
                                            </td>
                                            <td style="border:1px solid #000; padding:4px 6px; white-space:pre-wrap; font-size:9pt;">
                                                <t t-esc="adv.remarks or ''"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot>
                                    <tr style="font-weight:bold; background:#f1f8e9;">
                                        <td colspan="5" style="border:1px solid #000; padding:4px 6px; text-align:right;">
                                            Total Advance Requested
                                        </td>
                                        <td style="border:1px solid #000; padding:4px 6px; text-align:right;">
                                            <t t-esc="'%.2f' % sum(o.advance_ids.mapped('advance_amount'))"/>
                                        </td>
                                        <td style="border:1px solid #000; padding:4px 6px;"></td>
                                    </tr>
                                </tfoot>
                            </table>
                            <div style="margin-bottom:10px;"/>
                        </t>

                        <!-- ── AMOUNT SUMMARY (claim) ── -->
                        <t t-if="show_claim">
                            <t t-if="o.bill_line_ids">
                                <div style="background:#c8e6c9; padding:4px 8px; font-weight:bold; font-size:11pt; margin-bottom:4px;">
                                    Bill Attachments
                                </div>
                                <table style="width:100%; border-collapse:collapse; margin-bottom:4px;">
                                    <thead>
                                        <tr style="background:#c8e6c9;">
                                            <th style="border:1px solid #000; padding:4px 6px; text-align:left;">File Name</th>
                                            <th style="border:1px solid #000; padding:4px 6px; text-align:right;">Amount (NPR)</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="o.bill_line_ids" t-as="bl">
                                            <tr>
                                                <td style="border:1px solid #000; padding:4px 6px;">
                                                    <t t-esc="bl.bill_attachment_name or '—'"/>
                                                </td>
                                                <td style="border:1px solid #000; padding:4px 6px; text-align:right;">
                                                    <t t-esc="'%.2f' % bl.bill_amount"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                    <tfoot>
                                        <tr style="font-weight:bold; background:#f1f8e9;">
                                            <td style="border:1px solid #000; padding:4px 6px; text-align:right;">Total Bill Amount</td>
                                            <td style="border:1px solid #000; padding:4px 6px; text-align:right;">
                                                <t t-esc="'%.2f' % o.bill_amount"/>
                                            </td>
                                        </tr>
                                    </tfoot>
                                </table>
                                <div style="margin-bottom:8px;"/>
                            </t>

                            <div style="background:#c8e6c9; padding:4px 8px; font-weight:bold; font-size:11pt; margin-bottom:4px;">
                                Amount Summary
                            </div>
                            <table style="width:55%; border-collapse:collapse; margin-bottom:6px;">
                                <tr t-if="o.bill_amount">
                                    <td style="padding:4px 6px;"><strong>Total Bill Amount (NPR)</strong></td>
                                    <td style="padding:4px 6px; text-align:right;"><t t-esc="'%.2f' % o.bill_amount"/></td>
                                </tr>
                                <tr t-if="o.travel_line_ids">
                                    <td style="padding:4px 6px;"><strong>Travel Lines Total (NPR)</strong></td>
                                    <td style="padding:4px 6px; text-align:right;"><t t-esc="'%.2f' % o.travel_lines_amount"/></td>
                                </tr>
                                <tr style="font-weight:bold; border-top:1.5px solid #000;">
                                    <td style="padding:4px 6px;">Total Applied Amount (NPR)</td>
                                    <td style="padding:4px 6px; text-align:right;"><t t-esc="'%.2f' % o.amount"/></td>
                                </tr>
                            </table>
                            <t t-if="o.amount_breakdown">
                                <pre style="font-size:9pt; background:#f9f9f9; border:1px solid #ddd; padding:6px; margin-bottom:10px; white-space:pre-wrap;"><t t-esc="o.amount_breakdown"/></pre>
                            </t>
                        </t>

                        <!-- ── SIGNATURES ── -->
                        <table style="width:100%; margin-top:30px;">
                            <tr>
                                <td style="width:50%; text-align:center; padding:0 20px;">
                                    <div style="border-top:1.5px solid #000; padding-top:6px; display:inline-block; min-width:180px;">
                                        <strong>Submitted By</strong><br/>
                                        <t t-esc="o.submitted_by.name or '—'"/><br/>
                                        <span style="font-size:9pt; color:#555;">
                                            <t t-esc="o.employee_id.job_id.name or ''"/>
                                        </span>
                                    </div>
                                </td>
                                <td style="width:50%; text-align:center; padding:0 20px;">
                                    <div style="border-top:1.5px solid #000; padding-top:6px; display:inline-block; min-width:180px;">
                                        <strong>Approved By</strong><br/>
                                        <t t-esc="o.approved_by.name or '—'"/><br/>
                                        <span style="font-size:9pt; color:#555;">
                                            <t t-esc="o.approved_by.employee_ids[:1].job_id.name if o.approved_by.employee_ids else ''"/>
                                        </span>
                                    </div>
                                </td>
                            </tr>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
