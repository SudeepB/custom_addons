<odoo>

    <!-- Report Action — bound to model so it appears in Print menu -->
    <record id="action_report_tada_request" model="ir.actions.report">
        <field name="name">Travel Authorization Form</field>
        <field name="model">ks.tada.request</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ks_tada_management.report_tada_request_document</field>
        <field name="report_file">ks_tada_management.report_tada_request_document</field>
        <field name="binding_model_id" ref="model_ks_tada_request"/>
        <field name="binding_type">report</field>
    </record>

    <!-- QWeb Template -->
    <template id="report_tada_request_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: Arial, sans-serif; font-size: 11pt; color: #000;">

                        <!-- ── HEADER ── -->
                        <div style="text-align:center; margin-bottom:6px;">
                            <h2 style="margin:0; font-size:15pt; font-weight:bold; letter-spacing:1px;">
                                Karkhana Samuha
                            </h2>
                            <h3 style="margin:2px 0 0 0; font-size:13pt; font-weight:bold;">
                                Travel Authorization Form
                            </h3>
                        </div>

                        <!-- File name row -->
                        <table style="width:100%; margin-bottom:10px;">
                            <tr>
                                <td style="width:15%;"><strong>File Name:</strong></td>
                                <td>
                                    <t t-esc="(o.employee_id.name or '').lower().replace(' ','_')"/>_taf_<t t-esc="o.from_date.strftime('%d%m%Y') if o.from_date else ''"/>
                                </td>
                            </tr>
                        </table>
                        <hr style="border:1.5px solid #000; margin:4px 0 10px 0;"/>

                        <!-- ── PERSONAL INFORMATION ── -->
                        <div style="background:#c8e6c9; padding:4px 8px; font-weight:bold; font-size:11pt; margin-bottom:4px;">
                            Personal Information
                        </div>
                        <table style="width:100%; border-collapse:collapse; margin-bottom:10px;">
                            <tr>
                                <td style="width:20%; padding:4px 6px;"><strong>Name</strong></td>
                                <td style="width:35%; padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="o.employee_id.name or '—'"/>
                                </td>
                                <td style="width:15%; padding:4px 6px; text-align:right;"><strong>Signature</strong></td>
                                <td style="width:30%; padding:4px 6px; border-bottom:1px solid #000;"></td>
                            </tr>
                            <tr>
                                <td style="padding:4px 6px;"><strong>Designation</strong></td>
                                <td style="padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="o.employee_id.job_id.name or '—'"/>
                                </td>
                                <td></td><td></td>
                            </tr>
                            <tr>
                                <td style="padding:4px 6px;"><strong>Team / Department</strong></td>
                                <td style="padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="o.employee_id.department_id.name or '—'"/>
                                </td>
                                <td></td><td></td>
                            </tr>
                        </table>

                        <!-- ── TRAVEL INFORMATION ── -->
                        <div style="background:#c8e6c9; padding:4px 8px; font-weight:bold; font-size:11pt; margin-bottom:4px;">
                            Travel Information
                        </div>
                        <table style="width:100%; border-collapse:collapse; margin-bottom:10px;">
                            <tr>
                                <td style="width:20%; padding:4px 6px;"><strong>Purpose of Travel</strong></td>
                                <td style="width:35%; padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="o.purpose_of_travel or '—'"/>
                                </td>
                                <td style="width:15%; padding:4px 6px;"><strong>Project / Programme</strong></td>
                                <td style="width:30%; padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="o.project_title or '—'"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:4px 6px;"><strong>Date of Departure</strong></td>
                                <td style="padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="o.from_date.strftime('%d/%m/%Y') if o.from_date else '—'"/>
                                </td>
                                <td style="padding:4px 6px;"><strong>Date of Arrival</strong></td>
                                <td style="padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="o.to_date.strftime('%d/%m/%Y') if o.to_date else '—'"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:4px 6px;"><strong>Destination</strong></td>
                                <td style="padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="o.destination or '—'"/>
                                </td>
                                <td style="padding:4px 6px;"><strong>Travel Type</strong></td>
                                <td style="padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="dict(o._fields['travel_type'].selection).get(o.travel_type, '—')"/>
                                </td>
                            </tr>
                            <tr t-if="o.travel_type == 'residential'">
                                <td style="padding:4px 6px;"><strong>Full-Board Package</strong></td>
                                <td style="padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="'Yes' if o.full_board else 'No'"/>
                                </td>
                                <td style="padding:4px 6px;"><strong>Vehicle Provided by KS</strong></td>
                                <td style="padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="'Yes' if o.with_vehicle else 'No'"/>
                                </td>
                            </tr>
                            <tr t-if="o.travel_type == 'local'">
                                <td style="padding:4px 6px;"><strong>KM Travelled</strong></td>
                                <td style="padding:4px 6px; border-bottom:1px solid #000;">
                                    <t t-esc="o.km_travelled"/>
                                </td>
                                <td></td><td></td>
                            </tr>
                        </table>

                        <!-- ── TRAVEL ITINERARY ── -->
                        <t t-if="o.itinerary_ids">
                            <div style="background:#c8e6c9; padding:4px 8px; font-weight:bold; font-size:11pt; margin-bottom:4px;">
                                Travel Itinerary
                            </div>
                            <table style="width:100%; border-collapse:collapse; margin-bottom:10px;">
                                <thead>
                                    <tr style="background:#c8e6c9;">
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Date</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Travel From</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Travel To</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Mode of Transportation</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Remarks</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.itinerary_ids" t-as="itin">
                                        <tr>
                                            <td style="border:1px solid #000; padding:4px 6px;">
                                                <t t-esc="itin.date.strftime('%m/%d/%Y') if itin.date else '—'"/>
                                            </td>
                                            <td style="border:1px solid #000; padding:4px 6px;"><t t-esc="itin.travel_from or ''"/></td>
                                            <td style="border:1px solid #000; padding:4px 6px;"><t t-esc="itin.travel_to or ''"/></td>
                                            <td style="border:1px solid #000; padding:4px 6px;"><t t-esc="itin.mode_of_transport or ''"/></td>
                                            <td style="border:1px solid #000; padding:4px 6px;"><t t-esc="itin.remarks or ''"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- ── ADVANCE REQUEST ── -->
                        <t t-if="o.advance_ids">
                            <div style="background:#c8e6c9; padding:4px 8px; font-weight:bold; font-size:11pt; margin-bottom:4px;">
                                Advance Request
                            </div>
                            <table style="width:100%; border-collapse:collapse; margin-bottom:4px;">
                                <thead>
                                    <tr style="background:#c8e6c9;">
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Activity Code</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Budget Line Item</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:right;">Advance (A)</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:right;">Settled Expenses</th>
                                        <th style="border:1px solid #000; padding:4px 6px; text-align:left;">Remarks</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.advance_ids" t-as="adv">
                                        <tr>
                                            <td style="border:1px solid #000; padding:4px 6px;"><t t-esc="adv.activity_code or ''"/></td>
                                            <td style="border:1px solid #000; padding:4px 6px;"><t t-esc="adv.budget_line_item or ''"/></td>
                                            <td style="border:1px solid #000; padding:4px 6px; text-align:right;"><t t-esc="'%.2f' % adv.advance_amount"/></td>
                                            <td style="border:1px solid #000; padding:4px 6px; text-align:right;"><t t-esc="'%.2f' % adv.settled_expenses"/></td>
                                            <td style="border:1px solid #000; padding:4px 6px;"><t t-esc="adv.remarks or ''"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot>
                                    <tr style="font-weight:bold;">
                                        <td colspan="2" style="border:1px solid #000; padding:4px 6px; text-align:right;">Total Advance</td>
                                        <td style="border:1px solid #000; padding:4px 6px; text-align:right;">
                                            <t t-esc="'%.2f' % sum(o.advance_ids.mapped('advance_amount'))"/>
                                        </td>
                                        <td style="border:1px solid #000; padding:4px 6px; text-align:right;">
                                            <t t-esc="'%.2f' % sum(o.advance_ids.mapped('settled_expenses'))"/>
                                        </td>
                                        <td style="border:1px solid #000; padding:4px 6px; text-align:right;">
                                            <t t-esc="'%.2f' % (sum(o.advance_ids.mapped('advance_amount')) - sum(o.advance_ids.mapped('settled_expenses')))"/>
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                            <!-- Balance label -->
                            <div style="text-align:right; font-size:9pt; margin-bottom:10px; padding-right:2px;">
                                ← Balance (Advance − Settled)
                            </div>
                        </t>

                        <!-- ── AMOUNT SUMMARY ── -->
                        <div style="background:#c8e6c9; padding:4px 8px; font-weight:bold; font-size:11pt; margin-bottom:4px;">
                            Amount Summary
                        </div>
                        <table style="width:50%; border-collapse:collapse; margin-bottom:14px;">
                            <tr>
                                <td style="padding:4px 6px;"><strong>Total Bill Amount (NPR)</strong></td>
                                <td style="padding:4px 6px; text-align:right;"><t t-esc="'%.2f' % o.bill_amount"/></td>
                            </tr>
                            <tr style="font-weight:bold; border-top:1.5px solid #000;">
                                <td style="padding:4px 6px;">Total Applied Amount (NPR)</td>
                                <td style="padding:4px 6px; text-align:right;"><t t-esc="'%.2f' % o.amount"/></td>
                            </tr>
                        </table>

                        <!-- ── SIGNATURES ── -->
                        <table style="width:100%; margin-top:30px;">
                            <tr>
                                <td style="width:50%; text-align:center; padding:0 20px;">
                                    <div style="border-top:1.5px solid #000; padding-top:6px; display:inline-block; min-width:180px;">
                                        <strong>Submitted By</strong><br/>
                                        <t t-esc="o.submitted_by.name or '—'"/><br/>
                                        <span style="font-size:9pt; color:#555;">
                                            <t t-esc="o.employee_id.job_id.name or ''"/>
                                        </span>
                                    </div>
                                </td>
                                <td style="width:50%; text-align:center; padding:0 20px;">
                                    <div style="border-top:1.5px solid #000; padding-top:6px; display:inline-block; min-width:180px;">
                                        <strong>Approved By</strong><br/>
                                        <t t-esc="o.approved_by.name or '—'"/><br/>
                                        <span style="font-size:9pt; color:#555;">
                                            <t t-esc="o.approved_by.employee_ids[:1].job_id.name if o.approved_by.employee_ids else ''"/>
                                        </span>
                                    </div>
                                </td>
                            </tr>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
