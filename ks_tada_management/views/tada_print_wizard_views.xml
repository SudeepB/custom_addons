<odoo>

    <record id="view_tada_print_wizard_form" model="ir.ui.view">
        <field name="name">tada.print.wizard.form</field>
        <field name="model">ks.tada.print.wizard</field>
        <field name="arch" type="xml">
            <form string="Print TADA">
                <sheet>
                    <group>
                        <field name="request_id" readonly="1"/>
                        <field name="print_mode" string="What to Print" widget="radio"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_print"
                            type="object"
                            string="🖨 Print"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
