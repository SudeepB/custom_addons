<odoo>

    <!-- ── RATE RULE VIEWS ── -->
    <record id="view_tada_rate_rule_list" model="ir.ui.view">
        <field name="name">tada.rate.rule.list</field>
        <field name="model">ks.tada.rate.rule</field>
        <field name="arch" type="xml">
            <list string="TADA Rate Rules">
                <field name="name"/>
                <field name="travel_category"/>
                <field name="rate_per_day"/>
                <field name="rate_per_km"/>
                <field name="first_last_day_rate"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_tada_rate_rule_form" model="ir.ui.view">
        <field name="name">tada.rate.rule.form</field>
        <field name="model">ks.tada.rate.rule</field>
        <field name="arch" type="xml">
            <form string="TADA Rate Rule">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Rule Name"/></h1>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="travel_category"/>
                            <field name="active"/>
                        </group>
                        <group string="Rates (NPR)">
                            <field name="rate_per_day" string="Rate per Day"/>
                            <field name="first_last_day_rate" string="First / Last Day Rate"/>
                            <field name="rate_per_km" string="Rate per KM"/>
                            <field name="full_board_percent" string="Full-Board % of Base"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── PROGRAMME VIEWS ── -->
    <record id="view_tada_programme_list" model="ir.ui.view">
        <field name="name">tada.programme.list</field>
        <field name="model">ks.tada.programme</field>
        <field name="arch" type="xml">
            <list string="Programmes">
                <field name="name"/>
                <field name="purpose"/>
                <field name="default_activity_code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_tada_programme_form" model="ir.ui.view">
        <field name="name">tada.programme.form</field>
        <field name="model">ks.tada.programme</field>
        <field name="arch" type="xml">
            <form string="Programme / Project">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Programme / Project Name"/></h1>
                    </div>
                    <group>
                        <field name="purpose" string="Default Purpose of Travel"/>
                        <field name="default_activity_code" string="Default Activity Code"/>
                        <field name="active"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
