<odoo>

    <!-- LIST VIEW -->
    <record id="view_tada_list" model="ir.ui.view">
        <field name="name">tada.list</field>
        <field name="model">ks.tada.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="travel_type"/>
                <field name="amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- BILL FORM VIEW (popup for image preview) -->
    <record id="view_tada_bill_form" model="ir.ui.view">
        <field name="name">tada.bill.form</field>
        <field name="model">ks.tada.bill</field>
        <field name="arch" type="xml">
            <form string="Bill Detail">
                <sheet>
                    <group>
                        <field name="bill_attachment_name" string="File Name"/>
                        <field name="bill_amount" string="Amount (NPR)"/>
                    </group>
                    <group string="Bill Image">
                        <field name="bill_attachment" widget="image" string="" options="{'size': [600, 600]}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_tada_form" model="ir.ui.view">
        <field name="name">tada.form</field>
        <field name="model">ks.tada.request</field>
        <field name="arch" type="xml">
            <form string="TADA Request">

                <header>
                    <button name="action_submit" type="object" string="Submit" class="btn-primary"/>
                    <button name="action_approve" type="object" string="Approve" class="btn-success" groups="base.group_system"/>
                    <button name="action_reject" type="object" string="Reject" class="btn-danger" groups="base.group_system"/>
                    <button name="action_draft" type="object" string="Reset"/>
                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <group>
                        <group col="1">
                            <field name="name"/>
                            <field name="employee_id"/>
                            <field name="travel_type"/>
                            <field name="full_board" string="Full-Board Package"
                                   invisible="travel_type != 'residential'"/>
                            <field name="with_vehicle" string="Vehicle Provided by KS"
                                   invisible="travel_type != 'residential'"/>
                            <field name="destination"/>
                            <field name="from_date"/>
                            <field name="to_date"/>
                            <field name="km_travelled"
                                   invisible="travel_type != 'local'"/>
                            <field name="bill_amount" readonly="1"/>
                            <field name="amount" readonly="1"/>
                        </group>
                        <group col="1">
                            <field name="message_ids" widget="mail_thread"/>
                            <field name="approval_log" readonly="1"/>
                            <field name="amount_breakdown" readonly="1"/>
                            <field name="bill_line_ids" string="Bill Attachments">
                                <list string="Bills">
                                    <field name="bill_attachment_name" string="File Name"/>
                                    <field name="bill_amount" string="Amount (NPR)"/>
                                    <field name="bill_attachment" widget="image" string="Bill Image" options="{'size': [64, 64]}"/>
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="bill_attachment_name" string="File Name"/>
                                            <field name="bill_amount" string="Amount (NPR)"/>
                                        </group>
                                        <group string="Bill Image">
                                            <field name="bill_attachment" widget="image" string="" options="{'size': [600, 600]}"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </group>
                    </group>
                </sheet>

            </form>
        </field>
    </record>

</odoo>